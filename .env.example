# ==========================================================================
# Copy this file to ".env" (same folder as manage.py) and fill in real values.
# The ones marked REQUIRED are needed just to start the server + DB.
# Everything else enables optional features (AI agents, email, payments, AWS).
# ==========================================================================

# --- Database (REQUIRED) --------------------------------------------------
# You have "ODBC Driver 17 for SQL Server" installed, so override the default
# (which is Driver 18) with the line below.
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_NAME=your_database_name
DB_USER=your_db_username
DB_PASSWORD=your_db_password
# Set to 1 to use Windows Integrated Auth instead of DB_USER/DB_PASSWORD:
USE_WINDOWS_AUTH=0
USE_SQL_SERVER=1

# --- Celery / Redis (optional; needed for background jobs) ----------------
USE_REDIS=1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- URLs -----------------------------------------------------------------
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
SITE_URL=http://localhost:8000

# --- Email (optional) -----------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# --- AI providers (optional; enable the agents) ---------------------------
OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_REC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
EMBEDDING_PROVIDER=openai

# --- Stripe payments (optional) -------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AWS S3 storage (optional) --------------------------------------------
# Set USE_S3=True to store uploaded files (e.g. candidate CVs) on S3.
# When False (or unset), files are stored locally under media/.
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# --- Google OAuth (optional; meeting/calendar agent) ----------------------
# Platform OAuth app used for the per-company "Connect Google Calendar" flow
# (Company Profile -> Integrations). Create an OAuth client in Google Cloud
# Console, enable the Calendar API, and whitelist the redirect URI below.
GOOGLE_CLIENT_ID=1234567890-abcdefghijklmnop.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret_here
GOOGLE_REFRESH_TOKEN=
# Must exactly match an "Authorized redirect URI" in the Google Cloud OAuth app.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/company/integrations/google-calendar/callback
